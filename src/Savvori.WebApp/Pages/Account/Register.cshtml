@page
@model RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="min-h-[60vh] flex items-center justify-center py-8">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
        <div class="card-body">
            <h2 class="card-title text-2xl justify-center mb-2">Create your account 🛒</h2>
            <p class="text-center text-base-content/60 text-sm mb-4">Start saving on your grocery shopping</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-error mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <fieldset class="fieldset">
                    <label class="fieldset-label">Email address</label>
                    <input asp-for="Email" type="email" class="input input-bordered w-full"
                           placeholder="you@example.com" autocomplete="email" required />
                    <span asp-validation-for="Email" class="text-error text-xs"></span>
                </fieldset>

                <fieldset class="fieldset mt-3">
                    <label class="fieldset-label">Password</label>
                    <input asp-for="Password" type="password" class="input input-bordered w-full"
                           placeholder="At least 6 characters" autocomplete="new-password" required />
                    <span asp-validation-for="Password" class="text-error text-xs"></span>
                </fieldset>

                <fieldset class="fieldset mt-3">
                    <label class="fieldset-label">Confirm password</label>
                    <input asp-for="ConfirmPassword" type="password" class="input input-bordered w-full"
                           placeholder="Repeat your password" autocomplete="new-password" required />
                    <span asp-validation-for="ConfirmPassword" class="text-error text-xs"></span>
                </fieldset>

                <button type="submit" class="btn btn-primary w-full mt-6">Create account</button>
            </form>

            <div class="divider text-xs">Already have an account?</div>
            <a asp-page="/Account/Login" class="btn btn-outline btn-sm w-full">Sign in</a>
        </div>
    </div>
</div>
