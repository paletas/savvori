@model Savvori.WebApp.Services.ApiModels.ProductSummaryDto

<a asp-page="/Products/Detail" asp-route-id="@Model.Id"
   class="card bg-base-100 shadow hover:shadow-md border border-base-200 hover:border-primary transition-all cursor-pointer group">
    <figure class="px-4 pt-4 h-32 flex items-center justify-center">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="max-h-full max-w-full object-contain" loading="lazy" />
        }
        else
        {
            <div class="text-4xl text-base-content/20">🛒</div>
        }
    </figure>
    <div class="card-body p-3">
        <p class="text-xs font-medium line-clamp-2 group-hover:text-primary transition-colors leading-snug">@Model.Name</p>
        @if (!string.IsNullOrEmpty(Model.Brand))
        {
            <p class="text-xs text-base-content/50">@Model.Brand</p>
        }
        @if (Model.LowestPrice.HasValue)
        {
            <p class="text-primary font-bold text-sm mt-1">€@Model.LowestPrice.Value.ToString("F2")</p>
        }
        else
        {
            <p class="text-base-content/40 text-xs mt-1">Price unavailable</p>
        }
    </div>
</a>
