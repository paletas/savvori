@page
@model StoresIndexModel
@{
    ViewData["Title"] = "Stores";
    Layout = "_AdminLayout";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Store Chains</h1>
    <div class="badge badge-neutral">@Model.Chains.Count chain(s)</div>
</div>

@if (!Model.Chains.Any())
{
    <div class="alert alert-info">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span>No store chains found. Chains are created automatically when scrapers run.</span>
    </div>
}
else
{
    <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Slug</th>
                    <th>Base URL</th>
                    <th class="text-center">Locations</th>
                    <th class="text-center">Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var chain in Model.Chains)
                {
                    <tr>
                        <td class="font-medium">@chain.Name</td>
                        <td><span class="font-mono text-sm">@chain.Slug</span></td>
                        <td>
                            <a href="@chain.BaseUrl" target="_blank" rel="noopener noreferrer"
                               class="link link-primary text-sm truncate max-w-xs block">@chain.BaseUrl</a>
                        </td>
                        <td class="text-center">
                            <span class="badge badge-ghost">@chain.LocationCount</span>
                        </td>
                        <td class="text-center">
                            @if (chain.IsActive)
                            {
                                <span class="badge badge-success badge-sm">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-error badge-sm">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-page="/Admin/Stores/Detail" asp-route-slug="@chain.Slug"
                               class="btn btn-ghost btn-xs">Locations →</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
