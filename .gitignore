#
# .gitignore for .NET / Visual Studio / JetBrains Rider / VS Code
# Tailored for this repository to keep build artifacts, user-specific, and IDE files out of source control.
#

############################
# Build outputs
############################
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa]rtifacts/
[Bb]uild/
[Oo]ut/
[Pp]ublish/

############################
# Visual Studio / VS for Mac
############################
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.psess
*.vsp
*.vspx
*.pubxml.user

############################
# JetBrains Rider
############################
.idea/
*.sln.iml

############################
# Visual Studio Code (project-specific settings usually not required)
############################
.vscode/

############################
# Logs / temp
############################
*.log
logs/
*.tlog
*.tmp
*.temp
~$*
*~
*.bak
*.swp
*.swn
*.swo

############################
# Test results / coverage
############################
TestResults/
*.trx
*.coverage
*.coveragexml
coverage/
coverage*.json
coverage*.xml
*.opencover.xml
lcov.info

############################
# NuGet / packages
############################
packages/
*.nupkg
*.snupkg
project.lock.json
artifacts/
*.nuget.props
*.nuget.targets

############################
# Tools / analyzers caches
############################
_ReSharper*/
*.[Rr]e[Ss]harper
_NCrunch_*/
.*crunch*.local.xml
StyleCop.Cache

############################
# Secrets / env files
############################
.env
.env.*
*.secret*
*.secrets.json
secrets.json
local.settings.json

############################
# OS files
############################
.DS_Store
Thumbs.db

############################
# Node (if used for tooling)
############################
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

############################
# Tailwind generated CSS (built at compile time)
############################
src/Savvori.WebApp/wwwroot/css/site.css

############################
# EF Core / scaffolding
############################
ScaffoldingReadMe.txt

############################
# Playwright MCP snapshots
############################
.playwright-mcp/
